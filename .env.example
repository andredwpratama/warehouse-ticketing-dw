# ─── Database (REQUIRED) ───────────────────────────────────────────────
# Neon Postgres connection string. Get it from the Neon dashboard:
#   Project → Connection Details → copy the "pooled" connection string.
# Without this, /api/tickets returns 500 and the admin dashboard fails to load.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─── Email / Resend (OPTIONAL) ─────────────────────────────────────────
# Used to send ticket confirmation emails via Resend (https://resend.com).
# If RESEND_API_KEY is unset, ticket creation still works — the email step
# is skipped silently.
#
# RESEND_FROM must be either "onboarding@resend.dev" (Resend's test sender,
# only delivers to your own account email) or an address on a domain you've
# verified in the Resend dashboard, e.g. "Triatra <noreply@yourdomain.com>".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=andrepratamav15@gmail.com
SMTP_PASS=<App Password Gmail, 16 karakter>
SMTP_FROM=andrepratamav15@gmail.com
